frontend/package-lock.json
frontend/yarn.lock
# 前端缓存
frontend/.pnpm-store/
frontend/.nuxt/
# 后端Maven本地仓库
.m2/
# ==================== 系统/临时文件 ====================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.tmp
*.bak
# Mac
.DS_Store
.AppleDouble
.LSOverride
# Linux
*~
# 日志文件
*.log
*.logs/
# ==================== 环境配置 ====================
