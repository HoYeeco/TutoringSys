# MySQL Configuration
MYSQL_URL=jdbc:mysql://localhost:3306/tutoringsys_db?useSSL=false&serverTimezone=Asia/Shanghai
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_mysql_password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# LLM Configuration (Qwen AI)
LLM_API_KEY=your-qwen-api-key
LLM_MODEL=qwen-max
LLM_TIMEOUT=30000
LLM_RETRY=3

# File Upload Configuration
FILE_UPLOAD_DIR=./uploads
